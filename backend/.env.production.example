# Production Environment Variables for Backend (Render)

# Server
NODE_ENV=production
PORT=5000

# Database (PostgreSQL from Render or Supabase)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@host.render.com:5432/motherboard_db"

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-32-characters-minimum"
JWT_EXPIRE=24h

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Frontend URL (for CORS) - Update after deploying frontend
FRONTEND_URL="https://your-app.vercel.app"

# Optional: Twilio Status Callback (remove if causing issues)
# TWILIO_STATUS_CALLBACK="https://your-backend.onrender.com/api/twilio/status"
